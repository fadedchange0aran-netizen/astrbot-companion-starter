# Optional shared env file. Leave empty to use the local `.env`.
STACKCHAN_ENV_FILE=.env

STACKCHAN_APP_HOST=0.0.0.0
STACKCHAN_APP_PORT=3000
STACKCHAN_CONTROL_WS_HOST=0.0.0.0
STACKCHAN_CONTROL_WS_PORT=8765

STACKCHAN_DEFAULT_ROBOT_ID=
STACKCHAN_ADAPTER_URL=http://127.0.0.1:8001/v1/chat/completions
STACKCHAN_ADAPTER_KEY=
STACKCHAN_ASTRBOT_CONFIG_DIR=/AstrBot/data/config
# Optional explicit config file path. Takes precedence over STACKCHAN_ASTRBOT_CONFIG_DIR.
STACKCHAN_LLMPERCEPTION_CONFIG=

STACKCHAN_GROQ_API_KEY=
STACKCHAN_STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
STACKCHAN_VISION_API_URL=https://api.groq.com/openai/v1/chat/completions
STACKCHAN_MODEL_NAME=
STACKCHAN_VISION_MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct

STACKCHAN_VOICE_NAME=zh-CN-YunxiNeural
STACKCHAN_VOICE_WS_URL=
STACKCHAN_VOICE_WS_TOKEN=
STACKCHAN_CONTROL_WS_TOKEN=

STACKCHAN_VOICE_PROTOCOL_VERSION=1
STACKCHAN_VOICE_FINALIZE_SILENCE_SECONDS=0.25
STACKCHAN_VOICE_LISTENING_GUARD_MS=350

STACKCHAN_STT_HIGH_NO_SPEECH_PROB=0.72
STACKCHAN_STT_LOW_CONFIDENCE_NO_SPEECH_PROB=0.45
STACKCHAN_STT_LOW_CONFIDENCE_AVG_LOGPROB=-0.9
STACKCHAN_STT_VERY_LOW_AVG_LOGPROB=-1.2
STACKCHAN_STT_HIGH_COMPRESSION_RATIO=2.2
STACKCHAN_STT_MIN_PCM_RMS=220.0
STACKCHAN_STT_MIN_PCM_PEAK=900.0
STACKCHAN_STT_WEAK_AUDIO_MAX_RMS_DBFS=-45.0
STACKCHAN_STT_SPIKE_AUDIO_MAX_RMS=180.0
STACKCHAN_STT_SPIKE_AUDIO_MAX_RMS_DBFS=-44.0
STACKCHAN_STT_SPIKE_AUDIO_MIN_PEAK_RATIO=12.0
STACKCHAN_STT_FEEDBACK_COOLDOWN_SECONDS=6.0

STACKCHAN_TTS_SAMPLE_RATE=24000
STACKCHAN_TTS_FRAME_MS=60
STACKCHAN_TTS_OPUS_BITRATE=48k
STACKCHAN_FFMPEG_PATH=ffmpeg
STACKCHAN_PHOTO_DIR=photos
STACKCHAN_SHORT_HISTORY_TURNS=15
STACKCHAN_HTTP_TIMEOUT_SECONDS=45.0
