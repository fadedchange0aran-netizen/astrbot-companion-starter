# Optional shared env file
ARANBOX_ENV_FILE=.env

# Adapter base URL
ARANBOX_ADAPTER_URL=http://127.0.0.1:8001

# Prefer setting one explicit MCP-side token.
# Fallback order in code:
# 1. ARANBOX_ADAPTER_TOKEN
# 2. ARAN_MANUAL_BACKUP_TOKEN
# 3. ARAN_ADAPTER_TOKEN
ARANBOX_ADAPTER_TOKEN=

# Local file inspection paths
ARANBOX_BACKUP_ROOT=./runtime/adapter/backups
ARANBOX_TRANSCRIPT_ROOT=./runtime/adapter/transcripts
ARANBOX_SHARED_MEMORY_ROOT=./runtime/astrbot/aran_memory
ARANBOX_REPO_WORKSPACE_ROOT=./runtime/repo_workspace
ARANBOX_FILE_VAULT_ROOT=./runtime/astrbot/file_vault
ARANBOX_MEMORY_DB_PATH=./runtime/astrbot/aran_memory/memory_manager.db
ARANBOX_SAFE_DEPLOY_ENABLED=false
ARANBOX_SAFE_DEPLOY_ALLOWED_ACTIONS_JSON=["repo_git_status","sync_astrbot_plugins","restore_astrbot_plugins_latest_snapshot","deploy_astrbot_plugins_safe","restart_astrbot_container","restart_adapter_service","restart_adapter_service_safe","restart_mcp_service"]
ARANBOX_SAFE_DEPLOY_POLICY_PATH=./runtime/astrbot/mcp_safe_deploy_policy.json
ARANBOX_TOOL_ACCESS_REQUESTS_PATH=./runtime/astrbot/mcp_tool_access_requests.jsonl
ARANBOX_ENABLED_TOOL_LAYERS_JSON=["daily","extended"]
ARANBOX_DEFAULT_OWNER_ID=owner

# HTTP timeout
ARANBOX_REQUEST_TIMEOUT_SECONDS=30
ARANBOX_BIND_HOST=0.0.0.0
ARANBOX_BIND_PORT=9001

# Optional Notion integration
ARAN_NOTION_TOKEN=
ARAN_NOTION_PARENT_ID=

# Optional PushPlus notification
ARAN_PUSHPLUS_TOKEN=
ARAN_PUSHPLUS_TOPIC=

# Optional weather / map / mail / web tools
WEATHER_API_KEY=
AMAP_API_KEY=
AMAP_DEFAULT_ADDRESS=
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=
# Example: https://mcp.example.com
ARANBOX_WEB_PUBLIC_BASE_URL=
